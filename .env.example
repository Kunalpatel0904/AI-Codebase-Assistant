# Required — PocketFlow uses this to fetch repository files from GitHub
GITHUB_TOKEN=your_github_token_here

# Required — PocketFlow uses this for AI tutorial generation via Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — PocketFlow installation path
POCKETFLOW_PATH=D:\AI_Map\PocketFlow-Tutorial-Codebase-Knowledge-main

# Optional — Timeouts
DEFAULT_TIMEOUT=30
POCKETFLOW_TIMEOUT=300
