# ===========================================================================
# AI Codebase Assistant - Environment Configuration Template
# ===========================================================================

# Required - Google Gemini API Key for documentation generation
GEMINI_API_KEY=your_gemini_api_key_here

# Optional - Google Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Optional - GitHub Personal Access Token to avoid GitHub REST API rate limits
GITHUB_TOKEN=your_github_token_here

# Optional - Default HTTP request timeout in seconds (default: 30)
DEFAULT_TIMEOUT=30
